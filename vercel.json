{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.7.3"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ],
  "env": {
    "APP_ENV":  "production",
    "APP_URL":  "https://yvris-cloud.vercel.app",
    "APP_BASE": "",
    "DB_HOST":  "localhost",
    "DB_PORT":  "3306",
    "DB_NAME":  "yvris_cloud",
    "DB_USER":  "root",
    "DB_PASS":  ""
  }
}
